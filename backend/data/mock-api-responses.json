{
  "description": "Sample API responses for frontend mock or integration tests",
  "POST /lesson/start": {
    "request": { "theme": "caregiver", "goal_words": 20, "days": 7 },
    "response": {
      "session_id": "a1b2c3d4e5f6",
      "first_word": "medicine"
    }
  },
  "GET /lesson/word": {
    "request": "?theme=caregiver&session_id=a1b2c3d4e5f6",
    "response": {
      "word": "medicine",
      "theme": "caregiver",
      "image": "/images/medicine.png",
      "audio_url": "/audio/medicine.mp3",
      "sentence_examples": ["I need medicine", "I give medicine"]
    }
  },
  "GET /lesson/conversation": {
    "request": "?theme=caregiver",
    "response": {
      "theme": "caregiver",
      "turns": [
        { "speaker": "worker", "line": "Hello. How are you today?" },
        { "speaker": "user", "line": "I am good. Thank you." },
        { "speaker": "worker", "line": "Do you need medicine?" },
        { "speaker": "user", "line": "Yes. I need medicine." }
      ]
    }
  },
  "POST /progress/save": {
    "request": {
      "session_id": "a1b2c3d4e5f6",
      "word": "medicine",
      "sentence": "I give medicine",
      "correct": true,
      "stage": 2
    },
    "response": { "ok": true }
  },
  "GET /progress/:session_id": {
    "response": {
      "session_id": "a1b2c3d4e5f6",
      "words_learned": 5,
      "goal_words": 20,
      "theme": "caregiver",
      "streak_days": 2,
      "start_date": "2026-03-14",
      "words_completed": ["medicine", "help", "water", "food", "pain"]
    }
  },
  "POST /speech/check": {
    "request": { "expected": "I give medicine", "transcript": "I give medicine" },
    "response": { "correct": true, "similarity": 1 }
  },
  "POST /photo/identify": {
    "response": {
      "label": "medicine",
      "sentence_example": "I give medicine.",
      "success": true,
      "mock": true
    }
  }
}
